# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram channel ID (e.g., @your_channel_name or -1001234567890)
TELEGRAM_CHANNEL_ID=@uni_burn_alerts

# Ethereum RPC Configuration
# Use Alchemy for reliable access (get free key at alchemy.com)
# Same API key works across all Alchemy-supported chains
ALCHEMY_API_KEY=your_alchemy_api_key

# PostgreSQL Database Connection
# Required - Railway provides POSTGRES_URL automatically
DATABASE_URL=postgresql://user:password@localhost:5432/uniburn

# Monitoring Configuration
# How often to check for new burns (in seconds)
POLL_INTERVAL_SECONDS=60

# Your TokenJar monitor site URL (for "more info" links)
SITE_URL=https://your-tokenjar-site.com

# Amount threshold to trigger alerts (in wei)
# 4000 UNI = 4000000000000000000000
AMOUNT_THRESHOLD=4000000000000000000000

# Multi-chain Configuration
# Comma-separated list of chains to monitor
# Available: ethereum, unichain, arbitrum, base, optimism, worldchain, celo, soneium, xlayer, zora
# Default: ethereum (if not set, only Ethereum mainnet is monitored)
ENABLED_CHAINS=ethereum
